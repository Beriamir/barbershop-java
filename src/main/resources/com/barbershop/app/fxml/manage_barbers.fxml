<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barbershop.app.controller.ManageBarbersController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Manage Barbers" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Input form -->
    <GridPane hgap="10" vgap="8">
        <Label text="Full Name:"    GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Full Name"
                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>

        <Label text="Email:"        GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="emailField" promptText="Email"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Password:"     GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <PasswordField fx:id="passwordField" promptText="Password (leave blank to keep)"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <!-- Action buttons -->
    <HBox spacing="10">
        <Button text="Add Barber"    onAction="#handleAdd"    style="-fx-base: #27ae60; -fx-text-fill: white;"/>
        <Button text="Update Barber" onAction="#handleUpdate"/>
        <Button text="Clear Fields"  onAction="#handleClear"/>
    </HBox>

    <Label fx:id="messageLabel"/>

    <!-- Barbers table -->
    <TableView fx:id="barbersTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol"     text="Barber ID" prefWidth="80"/>
            <TableColumn fx:id="userIdCol" text="User ID"   prefWidth="70"/>
            <TableColumn fx:id="nameCol"   text="Name"      prefWidth="200"/>
            <TableColumn fx:id="emailCol"  text="Email"     prefWidth="220"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="Delete Selected" onAction="#handleDelete"
                style="-fx-text-fill: red;"/>
        <Button text="Refresh"         onAction="#handleRefresh"/>
        <Button text="Back"            onAction="#handleBack"/>
    </HBox>
</VBox>