<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.app.controller.AdminDashboardController">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label fx:id="welcomeLabel" text="Admin Dashboard" textFill="white" style="-fx-font-size: 16px;" />
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Manage Barbers" onAction="#handleManageBarbers"/>
            <Button text="Manage Services" onAction="#handleManageServices"/>
            <Button text="Manage Appointments" onAction="#handleManageAppointments"/>
            <Button text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Bookings per Barber" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <BarChart fx:id="bookingsChart" VBox.vgrow="ALWAYS">
                <xAxis><CategoryAxis label="Barber"/></xAxis>
                <yAxis><NumberAxis label="Bookings"/></yAxis>
            </BarChart>
        </VBox>
    </center>
</BorderPane>