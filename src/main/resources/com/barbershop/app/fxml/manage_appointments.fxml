<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.barbershop.app.controller.ManageAppointmentsController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="Manage Appointments"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <!-- ═══════════════════════════════════════════════════════════════
         WALK-IN BOOKING PANEL
         ═══════════════════════════════════════════════════════════════ -->
    <TitledPane text="Walk-in Booking" expanded="true"
                style="-fx-font-weight: bold;">
        <VBox spacing="10">
            <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

            <GridPane hgap="12" vgap="8">

                <Label text="Guest Name:"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="walkInNameField"
                           promptText="Customer's full name"
                           prefWidth="220"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Service:"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="walkInServiceCombo"
                          prefWidth="220"
                          GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Barber:"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="walkInBarberCombo"
                          prefWidth="220"
                          GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="Date:"
                       GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <DatePicker fx:id="walkInDatePicker"
                            prefWidth="220"
                            GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Time:"
                       GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="walkInTimeCombo"
                          prefWidth="220"
                          GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Book Walk-in"
                        onAction="#handleBookWalkIn"
                        style="-fx-base: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Clear"
                        onAction="#handleClearWalkIn"/>
            </HBox>

            <Label fx:id="walkInMessageLabel"/>
        </VBox>
    </TitledPane>

    <!-- ═══════════════════════════════════════════════════════════════
         FILTER BAR
         ═══════════════════════════════════════════════════════════════ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Filter by Status:"/>
        <ComboBox fx:id="statusFilterCombo" promptText="All"/>
        <Button text="Apply"    onAction="#handleFilter"/>
        <Button text="Show All" onAction="#handleShowAll"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="Refresh"  onAction="#handleRefresh"/>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════════════
         STATUS UPDATE BAR
         ═══════════════════════════════════════════════════════════════ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Set Status on Selected:"/>
        <ComboBox fx:id="newStatusCombo"/>
        <Button text="Update Status"   onAction="#handleUpdateStatus"/>
        <Button text="Cancel Selected" onAction="#handleCancelSelected"
                style="-fx-text-fill: #c0392b;"/>
    </HBox>

    <Label fx:id="messageLabel"/>

    <!-- ═══════════════════════════════════════════════════════════════
         APPOINTMENTS TABLE
         ═══════════════════════════════════════════════════════════════ -->
    <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol"       text="ID"       prefWidth="45"/>
            <TableColumn fx:id="customerCol" text="Customer" prefWidth="170"/>
            <TableColumn fx:id="barberCol"   text="Barber"   prefWidth="140"/>
            <TableColumn fx:id="serviceCol"  text="Service"  prefWidth="140"/>
            <TableColumn fx:id="dateCol"     text="Date"     prefWidth="95"/>
            <TableColumn fx:id="timeCol"     text="Time"     prefWidth="75"/>
            <TableColumn fx:id="statusCol"   text="Status"   prefWidth="110"/>
            <TableColumn fx:id="notesCol"    text="Notes"    prefWidth="150"/>
        </columns>
    </TableView>

    <!-- ═══════════════════════════════════════════════════════════════
         BOTTOM ACTIONS
         ═══════════════════════════════════════════════════════════════ -->
    <HBox spacing="10">
        <Button text="Delete Selected" onAction="#handleDelete"
                style="-fx-text-fill: red;"/>
        <Button text="Back"            onAction="#handleBack"/>
    </HBox>
</VBox>