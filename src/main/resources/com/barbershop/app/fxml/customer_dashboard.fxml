<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.barbershop.app.controller.CustomerDashboardController">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <Label fx:id="welcomeLabel" text="Welcome" textFill="white" style="-fx-font-size: 16px;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="Book Appointment" onAction="#handleBookAppointment"/>
            <Button text="My Bookings" onAction="#handleViewBookings"/>
            <Button text="Logout" onAction="#handleLogout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label text="Available Services" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="servicesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="serviceNameCol" text="Service" prefWidth="200"/>
                    <TableColumn fx:id="servicePriceCol" text="Price" prefWidth="100"/>
                    <TableColumn fx:id="serviceDurationCol" text="Duration (min)" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>